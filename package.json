{
  "name": "vue-admin",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "author": "如水 <rushui@qq.com>",
  "homepage": "https://github.com/vue-admin/vue-admin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vue-admin/vue-admin.git"
  },
  "bugs": {
    "url": "https://github.com/vue-admin/vue-admin/issues",
    "email": "rushui@qq.com"
  },
  "keywords": [
    "vue3",
    "vite",
    "typescript",
    "element-plus",
    "admin",
    "admin-dashboard",
    "rbac",
    "starter",
    "boilerplate",
    "pinia",
    "vue-router"
  ],
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check build-only",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "changelog": "git-cliff -o CHANGELOG.md --unreleased",
    "changelog:latest": "git-cliff -o CHANGELOG.md latest",
    "release:dry": "git-cliff --unreleased --strip header",
    "smoke": "playwright test",
    "smoke:ui": "playwright test --ui",
    "docs:dev": "vitepress dev docs-site",
    "docs:build": "vitepress build docs-site",
    "docs:preview": "vitepress preview docs-site"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@vueuse/core": "^11.3.0",
    "axios": "^1.18.1",
    "element-plus": "^2.14.2",
    "nprogress": "^0.2.0",
    "pinia": "^2.3.1",
    "vue": "^3.5.39",
    "vue-i18n": "9",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19",
    "@commitlint/config-conventional": "^19",
    "@eslint/js": "^9",
    "@playwright/test": "^1.48",
    "@types/node": "^22.20.0",
    "@types/nprogress": "^0.2.3",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.6",
    "@vitest/coverage-v8": "^3.2.6",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.1.3",
    "eslint": "^9",
    "eslint-import-resolver-typescript": "^3",
    "eslint-plugin-import": "^2",
    "eslint-plugin-vue": "^9",
    "git-cliff": "^2",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "mockjs": "^1.1.0",
    "npm-run-all": "^4.1.5",
    "sass": "^1.101.0",
    "sass-loader": "^13.3.3",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^7.3.6",
    "vite-plugin-mock": "^3.0.1",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.6",
    "vue-tsc": "^2.2.12"
  }
}
