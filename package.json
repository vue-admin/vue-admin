    "husky": "^9.1.7",
    "jsdom": "^24.1.3",
    "lint-staged": "^15",
    "mockjs": "^1.1.0",
    "npm-run-all": "^4.1.5",
    "sass": "^1.71.1",
    "sass-loader": "^13.3.3",
    "typescript": "~4.8.4",
    "unplugin-auto-import": "^0.15.3",
    "unplugin-vue-components": "^0.24.1",
    "vite": "^4.5.2",
